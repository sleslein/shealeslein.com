---
interface RaceRecord {
  race: string;
  w: number;
  l: number;
  d: number;
}

interface Props {
  overall: { w: number; l: number; d: number };
  byRace: RaceRecord[];
}

const { overall, byRace } = Astro.props;
---

<div class="stats-card">
  <h2>Record</h2>
  <div class="overall">
    <span class="w">{overall.w}W</span>
    <span class="sep">/</span>
    <span class="d">{overall.d}D</span>
    <span class="sep">/</span>
    <span class="l">{overall.l}L</span>
  </div>

  {byRace.length > 0 && (
    <table class="race-breakdown">
      <thead>
        <tr>
          <th>Race</th>
          <th>W</th>
          <th>D</th>
          <th>L</th>
        </tr>
      </thead>
      <tbody>
        {byRace.map(r => (
          <tr>
            <td>{r.race}</td>
            <td class="w">{r.w}</td>
            <td class="d">{r.d}</td>
            <td class="l">{r.l}</td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</div>

<style>
  .stats-card {
    margin-bottom: 2rem;
  }
  .overall {
    font-size: 1.5rem;
    font-weight: bold;
    margin-bottom: 1rem;
  }
  .sep {
    margin: 0 0.4rem;
    color: var(--text-muted, #888);
  }
  .w { color: green; }
  .l { color: red; }
  .d { color: goldenrod; }
  .race-breakdown {
    border-collapse: collapse;
  }
  .race-breakdown th,
  .race-breakdown td {
    padding: 0.25rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--border, #eee);
  }
  .race-breakdown th {
    font-weight: bold;
  }
</style>
